+    def reset_rng(self, rng: RNGLike | SeedLike | None = None) -> None:
+        """Reset the model random number generators.
+
+        Args:
+            rng: A new seed (or Generator / BitGenerator) for the RNG. If None, reset
+                using the stored initial RNG state.
+
+        Notes:
+            Mesa's random number generators are exposed as:
+            - ``self.rng`` (NumPy Generator)
+            - ``self.random`` (stdlib ``random.Random``)
+
+            ``reset_rng`` recreates the model's Scenario (preserving its parameters)
+            so that the scenario's ``rng`` and ``initial_rng_state`` remain
+            consistent with the model RNGs.
+        """
+        if rng is None:
+            try:
+                bg_class = getattr(np.random, self._rng["bit_generator"])
+            except (TypeError, KeyError, AttributeError):
+                # Fall back to NumPy's default seeding behavior.
+                rng = None
+            else:
+                bg = bg_class()
+                bg.state = self._rng
+                rng = np.random.Generator(bg)
+
+        scenario_cls = type(self.scenario)
+        scenario_kwargs = self.scenario.__dict__.copy()
+
+        try:
+            scenario = scenario_cls(
+                rng=rng,
+                scenario_id=self.scenario.scenario_id,
+                replication_id=self.scenario.replication_id,
+                **scenario_kwargs,
+            )
+        except TypeError:
+            # Some custom Scenario subclasses might not accept scenario_id /
+            # replication_id in their __init__. Preserve the user parameters.
+            scenario = scenario_cls(rng=rng, **scenario_kwargs)
+
+        self.scenario = scenario
+        self.rng = scenario.rng
+        self.random = random.Random(scenario._stdlib_seed)
+        self._rng = scenario.initial_rng_state
+
+        # Keep AgentSet RNGs consistent with the model RNG.
+        self._all_agents.random = self.random
+        for agent_set in self._agents_by_type.values():
+            agent_set.random = self.random
+
